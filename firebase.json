{
  "hosting": {
    "site": "genie-ai-1",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/pages/**",
        "destination": "/pages/[page]"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}